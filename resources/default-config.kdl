// prism-bar configuration.
//
// Lives at ~/.config/prism-bar/config.kdl (or $XDG_CONFIG_HOME/prism-bar/),
// overridable with $PRISM_BAR_CONFIG. Every setting below is optional;
// a missing file or omitted node means the built-in default. A file
// that fails to parse is an error — prism-bar will not silently fall
// back to defaults over a typo.
//
// Edits apply live: saving this file reconfigures running bars. A save
// that fails to parse logs the error and keeps the current config.

// Which outputs (connector names) get a bar. Repeat the node per
// output. Omitting every `output` node puts a bar on all outputs,
// including ones hotplugged later.
//
// output "DP-1"
// output "HDMI-A-1"

// Bar height in logical pixels.
height 40

// Floating margin off the screen edges, logical pixels. The bar's
// exclusive zone (the space tiled windows avoid) is height + margin.
margin 6

// Screen edge the bar docks to: "top" or "bottom".
position "top"

// Panel background alpha, 0.0 (invisible) to 1.0 (opaque).
opacity 0.8

// Panel corner radius in logical pixels.
radius 12

// Color palette. One of: "dark", "light", "slate-blue-dark",
// "slate-blue-light", "sand-amber-dark", "sand-amber-light",
// "mauve-violet-dark", "mauve-violet-light".
theme "dark"

// Whether the panel draws its border stroke.
border true

// System monitor poll cadence, seconds.
sample-interval 2

// Focused-window title truncation length, characters.
title-max-length 80

// Right-side modules, in display order. Presence enables a module;
// omitting the whole block keeps the default set shown here.
modules {
    // CPU load gauge (aggregate, from /proc/stat). Gauge options on
    // cpu/memory/disk: hot= is the integer percentage where the fill
    // switches to the destructive accent; width= and thickness= size
    // the bar in logical pixels.
    cpu hot=90 width=84 thickness=5

    // Memory usage gauge (1 - MemAvailable/MemTotal).
    memory hot=90

    // Disk usage gauge for a mount point (df semantics). Repeatable —
    // one gauge per node. Mounts other than "/" get a small path label
    // next to the icon.
    disk "/" hot=90
    // disk "/home"

    // Clock. format= is a chrono strftime string; it is validated at
    // startup. Non-digit text (e.g. day names from %a) can vary in
    // width; digits render in fixed slots and never jitter.
    clock format="%H:%M:%S"
    // clock format="%a %b %d  %H:%M"
}
